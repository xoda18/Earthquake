FROM python:3.11-slim

RUN apt-get update && apt-get install -y \
    libgl1 \
    libglib2.0-0 \
    libsm6 \
    libxext6 \
    libxrender-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY crack_detection/image_diff/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt requests

COPY crack_detection/image_diff/crop.py .
COPY crack_detection/image_diff/pipeline/ pipeline/

CMD ["python", "crop.py"]
